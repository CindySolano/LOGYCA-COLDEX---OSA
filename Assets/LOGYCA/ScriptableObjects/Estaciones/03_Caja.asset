%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 08db307493728f349ab82bc919ee218b, type: 3}
  m_Name: 03_Caja
  m_EditorClassIdentifier: Assembly-CSharp::LOGYCA.OSA.Data.EstacionData
  id: caja
  nombre: Cajas
  nombreLargo: Cajas registradoras
  subtitulo: Productos de impulso
  icono: {fileID: 21300000, guid: 050105768d3f7ca40979bdaecf8b46e5, type: 3}
  colorPrincipal: {r: 0.498, g: 0.467, b: 0.867, a: 1}
  camaraVirtualId: caja
  contexto: "En las cajas tienes 24 productos de impulso: chocolatinas, chicles,
    pilas, revistas. Solo 8 de cada 10 veces el cliente los encuentra disponibles,
    porque s\xF3lo se reponen al cambio de turno. Estos productos son los que m\xE1s
    margen dejan."
  pregunta: "\xBFQu\xE9 deber\xEDas hacer primero?"
  opciones:
  - letra: 65
    titulo: Poner una persona dedicada a reponer las cajas cada 2 horas
    esAcertada: 0
    deltaOsaPct: 4
    deltaInvDescriptivo: -2u
    deltaInvDir: 1
    deltaSosPct: 1
    kpis:
    - tipo: 0
      direccion: 0
      valorDescriptivo: Sube de 82% a 93%
    - tipo: 1
      direccion: 1
      valorDescriptivo: "Baja de 6 a 4 d\xEDas"
    - tipo: 2
      direccion: 2
      valorDescriptivo: Igual
    - tipo: 3
      direccion: 2
      valorDescriptivo: Igual
    - tipo: 4
      direccion: 2
      valorDescriptivo: Igual
    - tipo: 5
      direccion: 0
      valorDescriptivo: +11% (sueldo del reponedor)
    - tipo: 6
      direccion: 0
      valorDescriptivo: +15% en impulso
    - tipo: 7
      direccion: 0
      valorDescriptivo: +18%
    - tipo: 8
      direccion: 0
      valorDescriptivo: Sube
    nivelColaboracion: 1
    feedbackCadena: "La cadena gana mucho porque el impulso es de los productos con
      m\xE1s margen. El sueldo del reponedor se paga solo con las ventas extras."
    feedbackProveedor: "Vende un poco m\xE1s, pero sin enterarse. Para \xE9l es una
      venta normal, no hay nada distinto en la relaci\xF3n."
    veredicto: La cadena resuelve sola y gana. El proveedor se beneficia indirectamente
      pero queda fuera de la jugada.
    animacionMercaderista: Reponer
  - letra: 66
    titulo: "Que la marca l\xEDder gestione y reponga toda la zona de cajas (delegaci\xF3n)"
    esAcertada: 0
    deltaOsaPct: 5
    deltaInvDescriptivo: -3u
    deltaInvDir: 1
    deltaSosPct: -2
    kpis:
    - tipo: 0
      direccion: 0
      valorDescriptivo: Sube de 82% a 96%
    - tipo: 1
      direccion: 1
      valorDescriptivo: "Baja de 6 a 3 d\xEDas"
    - tipo: 2
      direccion: 0
      valorDescriptivo: Optimizado por la marca
    - tipo: 3
      direccion: 1
      valorDescriptivo: "Reposici\xF3n diaria"
    - tipo: 4
      direccion: 2
      valorDescriptivo: Asumido por el proveedor
    - tipo: 5
      direccion: 1
      valorDescriptivo: -8% (lo asume el proveedor)
    - tipo: 6
      direccion: 0
      valorDescriptivo: +22% en impulso
    - tipo: 7
      direccion: 0
      valorDescriptivo: +25%
    - tipo: 8
      direccion: 0
      valorDescriptivo: Sube
    nivelColaboracion: 2
    feedbackCadena: "No tienes que preocuparte por las cajas: la marca repone, decide
      variedad y asume el riesgo. La cadena cobra por el espacio y por la venta.
      Pero pierde control de la zona m\xE1s rentable."
    feedbackProveedor: "Tiene control total de la mejor zona de la tienda. Decide
      qu\xE9 exhibir seg\xFAn ventas reales y captura todo el valor."
    veredicto: "Esto no es colaboraci\xF3n, es delegaci\xF3n. Funciona pero es transaccional.
      Si la marca cambia de estrategia, la cadena queda expuesta."
    animacionMercaderista: Delegar
  - letra: 67
    titulo: "Comit\xE9 conjunto cadena-proveedor con datos en tiempo real"
    esAcertada: 1
    deltaOsaPct: 6
    deltaInvDescriptivo: -3u
    deltaInvDir: 1
    deltaSosPct: 3
    kpis:
    - tipo: 0
      direccion: 0
      valorDescriptivo: Sube de 82% a 94%
    - tipo: 1
      direccion: 1
      valorDescriptivo: "Baja de 6 a 3 d\xEDas"
    - tipo: 2
      direccion: 0
      valorDescriptivo: Optimizado por datos
    - tipo: 3
      direccion: 1
      valorDescriptivo: "Reposici\xF3n ajustada"
    - tipo: 4
      direccion: 2
      valorDescriptivo: Igual
    - tipo: 5
      direccion: 0
      valorDescriptivo: "+5% (comit\xE9 y software)"
    - tipo: 6
      direccion: 0
      valorDescriptivo: +19% en impulso
    - tipo: 7
      direccion: 0
      valorDescriptivo: +21%
    - tipo: 8
      direccion: 0
      valorDescriptivo: Sube
    nivelColaboracion: 4
    feedbackCadena: "Mantienes el control de la zona y sum\xE1s la inteligencia del
      proveedor. Ambos ven los datos en tiempo real y ajustan juntos."
    feedbackProveedor: "Participa en decisiones reales, no solo despacha. Aporta
      conocimiento de categor\xEDa y aprende del comportamiento de compra en esta
      tienda."
    veredicto: Ganan los dos sin que ninguno pierda control. Esta es la diferencia
      entre delegar (B) y colaborar (C).
    animacionMercaderista: Colaborar
