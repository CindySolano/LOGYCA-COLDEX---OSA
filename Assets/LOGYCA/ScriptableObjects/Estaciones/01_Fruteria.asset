MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 08db307493728f349ab82bc919ee218b, type: 3}
  m_Name: 01_Fruteria
  m_EditorClassIdentifier: Assembly-CSharp::LOGYCA.OSA.Data.EstacionData
  id: fruteria
  nombre: "Fruter\xEDa"
  subtitulo: "Rotaci\xF3n y mermas"
  icono: {fileID: 0}
  colorPrincipal: {r: 0.961, g: 0.376, b: 0.118, a: 1}
  camaraVirtualId: fruteria
  contexto: "La fruter\xEDa tiene mermas del 12% esta semana. La fruta que se da\xF1a
    es la que est\xE1 al fondo del exhibidor."
  pregunta: "\xBFQu\xE9 deber\xEDas hacer primero?"
  opciones:
  - letra: 65
    titulo: 'Rotar fruta: pasar la del fondo al frente'
    esAcertada: 1
    deltaOsaPct: 4
    deltaInvDescriptivo: "\u2192 0"
    deltaInvDir: 2
    deltaSosPct: 2
    labelEstadoZona: "FRUTER\xCDA ROTADA"
    animacionMercaderista: Rotar
    porque: "Rotar la fruta protege OSA sin sacrificar inventario. La merma baja
      porque la fruta vieja sale antes de da\xF1arse."
    nivelColaboracion: 1
  - letra: 66
    titulo: Bajar el precio de la fruta del fondo
    esAcertada: 0
    deltaOsaPct: -2
    deltaInvDescriptivo: "\u22121u"
    deltaInvDir: 1
    deltaSosPct: -1
    labelEstadoZona: "FRUTER\xCDA EN PROMOCI\xD3N"
    animacionMercaderista: Promocion
    porque: "Resolviste hoy con descuento, pero la merma estructural sigue ah\xED
      y el margen se redujo."
    nivelColaboracion: 1
  - letra: 67
    titulo: "Pedir menos fruta al pr\xF3ximo despacho"
    esAcertada: 0
    deltaOsaPct: -6
    deltaInvDescriptivo: "\u22123u"
    deltaInvDir: 1
    deltaSosPct: -4
    labelEstadoZona: "FRUTER\xCDA SIN ATENDER"
    animacionMercaderista: PedirMenos
    porque: "Pedir menos baja la merma pero tambi\xE9n el OSA y el espacio en g\xF3ndola.
      La competencia ocupa el aire que cediste."
    nivelColaboracion: 2
